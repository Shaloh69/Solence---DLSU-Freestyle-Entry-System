# --- Solence frontend (Next.js) ---

# Express API base URL (REST + /ws realtime)
# When hosting via Cloudflare Tunnel, use the public API hostname
# instead (see /docs/HOSTING.md), e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase (client-side; auth integration pending)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
