# --- Solence API (Express) ---
PORT=4000

# Comma-separated list of allowed CORS origins
# When hosting via Cloudflare Tunnel, add the public app hostname
# (see /docs/HOSTING.md), e.g. http://localhost:3000,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Supabase (server-side — use the service role key, never expose to clients)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Tier used when no x-solence-tier header is sent: free | pro | firm | lgu.
# Placeholder until Supabase auth carries a plan per user.
DEFAULT_TIER=pro

# solence-vision base URL (brief §7.4) — Express is its only caller,
# the frontend never connects to it directly.
VISION_URL=http://localhost:8000
